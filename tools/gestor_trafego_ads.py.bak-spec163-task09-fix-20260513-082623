async def _resolve_accounts(conn: asyncpg.Connection, scope_type: str | None, scope_key: str | None, q: str | None = None) -> list[dict[str, Any]]:
    scope_type = (scope_type or "").strip().lower()
    scope_key = (scope_key or "").strip()
    q = (q or "").strip()
    rows: list[asyncpg.Record]
    if scope_type == "group":
        rows = await conn.fetch(
            """
            SELECT a.* FROM ads.account_group_members m
            JOIN ads.accounts a ON a.ad_account_id = m.ad_account_id
            WHERE m.group_key = $1
            ORDER BY a.business_key, a.account_name
            """,
            scope_key,
        )
    elif scope_type == "business":
        rows = await conn.fetch("SELECT * FROM ads.accounts WHERE business_key=$1 ORDER BY account_name", scope_key)
    elif scope_type == "account":
        rows = await conn.fetch(
            """
            SELECT * FROM ads.accounts
            WHERE (ad_account_id=$1 OR account_id=$1 OR lower(account_name) LIKE lower($2))
            ORDER BY account_name LIMIT 20
            """,
            scope_key,
            f"%{scope_key}%",
        )
    elif scope_type == "mentee":
        needle = scope_key or q
        rows = await conn.fetch(
            """
            SELECT * FROM ads.accounts
            WHERE business_key='mentorada'
              AND (lower(account_name) LIKE lower($1) OR lower(coalesce(tenant_key,'')) LIKE lower($1))
            ORDER BY account_name LIMIT 20
            """,
            f"%{needle}%",
        )
    else:
        needle = q or scope_key
        if not needle:
            rows = []
        else:
            rows = await conn.fetch(
                """
                SELECT * FROM ads.accounts
                WHERE (lower(account_name) LIKE lower($1) OR lower(coalesce(tenant_key,'')) LIKE lower($1) OR lower(business_key) LIKE lower($1))
                ORDER BY business_key, account_name LIMIT 20
                """,
                f"%{needle}%",
            )
    return [dict(r) for r in rows]


async def _offer_patterns(conn: asyncpg.Connection, group_key: str | None, offer_key: str | None) -> list[dict[str, Any]]:
    if not offer_key:
        return []
    rows = await conn.fetch(
        """
        SELECT * FROM ads.offer_mappings
        WHERE active = TRUE AND ($1::text IS NULL OR group_key=$1) AND offer_key=$2
        ORDER BY confidence DESC
        """,
        group_key,
        offer_key,
    )
    return [dict(r) for r in rows]


def _row_matches_offer(row: asyncpg.Record | dict[str, Any], patterns: list[dict[str, Any]]) -> bool:
    if not patterns:
        return True
    for p in patterns:
        field = p.get("match_field") or "any"
        pattern = (p.get("match_pattern") or "").replace("\\m", r"\b").replace("\\M", r"\b")
        values: list[str]
        if field == "any":
            values = [str(row.get(k) or "") for k in ("campaign_name", "adset_name", "ad_name", "account_name")]
        else:
            values = [str(row.get(field) or "")]
        try:
            if re.search(pattern, " ".join(values), re.I):
                return True
        except re.error:
            if pattern.lower() in " ".join(values).lower():
                return True
    return False


async def _aggregate_postgres(conn: asyncpg.Connection, accounts: list[dict[str, Any]], start: str, end: str, patterns: list[dict[str, Any]]) -> dict[str, Any]:
    if not accounts:
        return {"spend": 0, "impressions": 0, "clicks": 0, "leads": 0, "accounts": [], "by_account": [], "level_note": "nenhuma_conta"}
    ids = [a["ad_account_id"] for a in accounts]
    rows = await conn.fetch(
        """
        WITH preferred AS (
          SELECT ad_account_id, date,
                 MAX(CASE level WHEN 'ad' THEN 3 WHEN 'adset' THEN 2 ELSE 1 END) AS prio
          FROM ads.daily_insights
          WHERE ad_account_id = ANY($1::text[]) AND date BETWEEN $2::date AND $3::date
          GROUP BY ad_account_id, date
        )
        SELECT a.account_name, a.business_key, a.tenant_key, i.*
        FROM ads.daily_insights i
        JOIN preferred p ON p.ad_account_id=i.ad_account_id AND p.date=i.date
          AND p.prio = CASE i.level WHEN 'ad' THEN 3 WHEN 'adset' THEN 2 ELSE 1 END
        JOIN ads.accounts a ON a.ad_account_id=i.ad_account_id
        WHERE i.ad_account_id = ANY($1::text[]) AND i.date BETWEEN $2::date AND $3::date
        """,
        ids,
        start,
        end,
    )
    filtered = [r for r in rows if _row_matches_offer(r, patterns)]
    by: dict[str, dict[str, Any]] = {}
    totals = {"spend": Decimal("0"), "impressions": 0, "clicks": 0, "leads": 0}
    min_date = None
    max_date = None
    for r in filtered:
        aid = r["ad_account_id"]
        item = by.setdefault(aid, {"ad_account_id": aid, "account_name": r["account_name"], "spend": Decimal("0"), "impressions": 0, "clicks": 0, "leads": 0})
        spend = r["spend"] or Decimal("0")
        item["spend"] += spend
        item["impressions"] += int(r["impressions"] or 0)
        item["clicks"] += int(r["clicks"] or 0)
        item["leads"] += int(r["leads"] or 0)
        totals["spend"] += spend
        totals["impressions"] += int(r["impressions"] or 0)
        totals["clicks"] += int(r["clicks"] or 0)
        totals["leads"] += int(r["leads"] or 0)
        min_date = r["date"] if min_date is None or r["date"] < min_date else min_date
        max_date = r["date"] if max_date is None or r["date"] > max_date else max_date
    by_rows = list(by.values())
    by_rows.sort(key=lambda x: float(x["spend"] or 0), reverse=True)
    spend = totals["spend"]
    leads = totals["leads"]
    cpl = (spend / Decimal(leads)).quantize(Decimal("0.01")) if leads else None
    return {
        "spend": spend,
        "impressions": totals["impressions"],
        "clicks": totals["clicks"],
        "leads": leads,
        "cpl": cpl,
        "period_available_start": min_date,
        "period_available_end": max_date,
        "accounts": ids,
        "by_account": by_rows[:20],
        "rows_used": len(filtered),
        "rows_seen": len(rows),
        "level_note": "preferiu ad > adset > campaign por conta/dia para evitar duplicidade",
    }


def _load_env_file_value(key: str) -> str | None:
    for path in (Path("/root/.hermes/.env"), Path("/etc/meta-ads-relatorio/env")):
        try:
            for line in path.read_text(encoding="utf-8").splitlines():
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                k, v = line.split("=", 1)
                if k.strip() == key:
                    return v.strip().strip('"').strip("'")
        except Exception:
            continue
    return None


def _token_for_account(account: dict[str, Any]) -> str | None:
    alias = str(account.get("token_alias") or "")
    return (
        os.getenv(alias)
        or _load_env_file_value(alias)
        or os.getenv("META_ACCESS_TOKEN")
        or _load_env_file_value("META_ACCESS_TOKEN")
        or os.getenv("META_ADS_RELATORIO_TOKEN")
        or _load_env_file_value("META_ADS_RELATORIO_TOKEN")
    )


def _extract_leads(actions: Any) -> int:
    if not isinstance(actions, list):
        return 0
    total = 0
    for item in actions:
        if not isinstance(item, dict):
            continue
        at = str(item.get("action_type") or "")
        if "lead" in at or "messaging_conversation_started" in at:
            try:
                total += int(float(item.get("value") or 0))
            except Exception:
                pass
    return total


async def _aggregate_meta_export(conn: asyncpg.Connection, group_key: str | None, start: date, end: date) -> dict[str, Any] | None:
    if group_key != "des":
        return None
    row = await conn.fetchrow(
        """
        SELECT *
        FROM ads.meta_ads_exports
        WHERE group_key=$1 AND is_summary=TRUE
          AND report_start <= $3::date AND report_end >= $2::date
        ORDER BY created_at DESC
        LIMIT 1
        """,
        group_key,
        start,
        end,
    )
    if not row:
        return None
    details = await conn.fetch(
        """
        SELECT account_name, sum(spend) AS spend, sum(message_conversations)::bigint AS leads
        FROM ads.meta_ads_exports
        WHERE group_key=$1 AND is_summary=FALSE AND source_file=$2
        GROUP BY account_name
        ORDER BY spend DESC
        """,
        group_key,
        row["source_file"],
    )
    spend = row["spend"] or Decimal("0")
    leads = int(row["message_conversations"] or 0)
    cpl = (spend / Decimal(leads)).quantize(Decimal("0.01")) if leads else None
    return {
        "spend": spend,
        "impressions": 0,
        "clicks": 0,
        "leads": leads,
        "cpl": cpl,
        "period_available_start": row["report_start"],
        "period_available_end": row["report_end"],
        "accounts": [d["account_name"] for d in details],
        "by_account": [
            {"account_name": d["account_name"], "spend": d["spend"], "leads": d["leads"]}
            for d in details
        ],
        "rows_used": len(details),
        "rows_seen": len(details),
        "level_note": "usou export Meta do pool DES; fonte cobre o periodo solicitado e inclui multiplas contas DES",
        "data_source": "meta_export_pool",
        "source_file": row["source_file"],
    }


async def _fetch_meta_api(accounts: list[dict[str, Any]], start: str, end: str, level: str = "campaign") -> dict[str, Any]:
    totals = {"spend": Decimal("0"), "impressions": 0, "clicks": 0, "leads": 0, "errors": []}
    by_account = []
    for acc in accounts:
        token = _token_for_account(acc)
        if not token:
            totals["errors"].append({"account": acc.get("account_name"), "error": "token_missing"})
            continue
        params = {
            "access_token": token,
            "time_range": json.dumps({"since": _date_s(start), "until": _date_s(end)}),
            "time_increment": "1",
            "level": level,
            "fields": "date_start,date_stop,campaign_id,campaign_name,adset_id,adset_name,ad_id,ad_name,spend,impressions,reach,clicks,ctr,cpc,cpm,frequency,actions",
            "limit": "200",
        }
        url = f"{GRAPH_BASE_URL}/{acc['ad_account_id']}/insights"
        acc_sum = {"ad_account_id": acc["ad_account_id"], "account_name": acc.get("account_name"), "spend": Decimal("0"), "impressions": 0, "clicks": 0, "leads": 0, "rows": 0}
        pages = 0
        try:
            while url and pages < 25:
                resp = requests.get(url, params=params if pages == 0 else None, timeout=30)
                if resp.status_code >= 400:
                    totals["errors"].append({"account": acc.get("account_name"), "status": resp.status_code, "error": resp.text[:300]})
                    break
                payload = resp.json()
                for row in payload.get("data", []) or []:
                    spend = Decimal(str(row.get("spend") or "0"))
                    leads = _extract_leads(row.get("actions"))
                    acc_sum["spend"] += spend
                    acc_sum["impressions"] += int(float(row.get("impressions") or 0))
                    acc_sum["clicks"] += int(float(row.get("clicks") or 0))
                    acc_sum["leads"] += leads
                    acc_sum["rows"] += 1
                url = (payload.get("paging") or {}).get("next")
                params = None
                pages += 1
        except Exception as exc:
            totals["errors"].append({"account": acc.get("account_name"), "error": str(exc)[:300]})
        totals["spend"] += acc_sum["spend"]
        totals["impressions"] += acc_sum["impressions"]
        totals["clicks"] += acc_sum["clicks"]
        totals["leads"] += acc_sum["leads"]
        by_account.append(acc_sum)
    leads = totals["leads"]
    cpl = (totals["spend"] / Decimal(leads)).quantize(Decimal("0.01")) if leads else None
    return {**totals, "cpl": cpl, "by_account": by_account, "data_source": "meta_api"}


async def _ads_historico_health(args: dict[str, Any], **_: Any) -> str:
    conn = await _connect()
    try:
        groups = [dict(r) for r in await conn.fetch("SELECT * FROM ads.v_account_groups ORDER BY group_key")]
        hist = dict(await conn.fetchrow("SELECT min(date)::text AS min_date, max(date)::text AS max_date, count(*)::int AS rows, count(DISTINCT ad_account_id)::int AS accounts FROM ads.daily_insights"))
        funnel = dict(await conn.fetchrow("SELECT count(*)::int AS rows, min(date)::text AS min_date, max(date)::text AS max_date FROM ads.funnel_daily"))
        inputs = dict(await conn.fetchrow("SELECT count(*)::int AS rows FROM ads.period_inputs WHERE is_test=FALSE"))
        return _json({"success": True, "history": hist, "groups": groups, "funnel_daily": funnel, "period_inputs": inputs})
    finally:
        await conn.close()


async def _resolver_agrupamento_meta(args: dict[str, Any], **_: Any) -> str:
    conn = await _connect()
    try:
        q = str(args.get("q") or args.get("texto") or "").strip()
        groups = [dict(r) for r in await conn.fetch("SELECT * FROM ads.v_account_groups ORDER BY group_key")]
        accounts = await _resolve_accounts(conn, args.get("scope_type"), args.get("scope_key"), q)
        offers = [dict(r) for r in await conn.fetch("SELECT group_key, offer_key, offer_name, match_field, match_pattern, confidence, notes FROM ads.offer_mappings WHERE active=TRUE ORDER BY group_key, offer_key, confidence DESC")]
        return _json({"success": True, "q": q, "groups": groups, "accounts_found": accounts[:20], "offer_mappings": offers})
    finally:
        await conn.close()


async def _get_ads_historico(args: dict[str, Any], **_: Any) -> str:
    requester = _requester(args)
    if not _is_traffic_allowed(requester):
        return _json({"success": False, "error": "acesso_negado"})
    start, end = _period(args)
    scope_type = args.get("scope_type") or ("group" if args.get("grupo") else "mentee" if args.get("mentorada") else "account" if args.get("conta") else None)
    scope_key = args.get("scope_key") or args.get("grupo") or args.get("mentorada") or args.get("conta")
    offer_key = args.get("offer_key") or args.get("oferta")
    conn = await _connect()
    try:
        accounts = await _resolve_accounts(conn, scope_type, scope_key, args.get("q"))
        patterns = await _offer_patterns(conn, args.get("grupo") or (scope_key if scope_type == "group" else None), offer_key)
        result = await _aggregate_meta_export(conn, scope_key if scope_type == "group" else None, start, end) or await _aggregate_postgres(conn, accounts, start, end, patterns)
        result.update({"success": True, "scope_type": scope_type, "scope_key": scope_key, "offer_key": offer_key, "period_start": start, "period_end": end, "data_source": "postgres_history"})
        await _audit(conn, "get_ads_historico", {**args, "scope_type": scope_type, "scope_key": scope_key, "offer_key": offer_key, "period_start": start, "period_end": end}, {"spend": result.get("spend"), "leads": result.get("leads"), "accounts": len(accounts)})
        return _json(result)
    finally:
        await conn.close()


async def _get_meta_ads_periodo(args: dict[str, Any], **_: Any) -> str:
    requester = _requester(args)
    if not _is_traffic_allowed(requester):
        return _json({"success": False, "error": "acesso_negado"})
    start, end = _period(args)
    scope_type = args.get("scope_type") or ("group" if args.get("grupo") else "account")
    scope_key = args.get("scope_key") or args.get("grupo") or args.get("conta")
    conn = await _connect()
    try:
        accounts = await _resolve_accounts(conn, scope_type, scope_key, args.get("q"))
        limit = int(args.get("limit") or 10)
        level = str(args.get("level") or "campaign")
        result = await _fetch_meta_api(accounts[:limit], start, end, level=level)
        result.update({"success": True, "scope_type": scope_type, "scope_key": scope_key, "period_start": start, "period_end": end, "level": level, "accounts_requested": len(accounts[:limit])})
        await _audit(conn, "get_meta_ads_periodo", {**args, "scope_type": scope_type, "scope_key": scope_key, "period_start": start, "period_end": end}, {"spend": result.get("spend"), "leads": result.get("leads"), "errors": len(result.get("errors") or [])})
        return _json(result)
    finally:
        await conn.close()


