def _period(args: dict[str, Any]) -> tuple[date, date]:
    start = args.get("data_inicio") or args.get("period_start") or args.get("start")
    end = args.get("data_fim") or args.get("period_end") or args.get("end")
    if not start or not end:
        raise ValueError("data_inicio e data_fim sao obrigatorios no formato YYYY-MM-DD")
    if isinstance(start, date) and isinstance(end, date):
        return start, end
    return date.fromisoformat(str(start)[:10]), date.fromisoformat(str(end)[:10])


def _date_s(value: Any) -> str:
    return value.isoformat() if isinstance(value, date) else str(value)[:10]


def _money(value: Any) -> str:
    value = float(value or 0)
    return (f"R$ {value:,.2f}".replace(",", "X").replace(".", ",").replace("X", "."))


def _pct(value: Any) -> str:
    if value is None:
        return "n/d"
    return f"{float(value):.2f}%".replace(".", ",")


