ACK_PATTERNS = [
    re.compile(r"\b(?:vi|assumi|peguei|tratado|ok|ack)\s*#\s*(\d+)\b", re.I),
    re.compile(r"\bj[aá]\s+vi\s*#\s*(\d+)\b", re.I),
]

_pool: asyncpg.Pool | None = None
_dri_config: dict[str, Any] | None = None


async def _get_pool() -> asyncpg.Pool:
    global _pool
    if _pool is None:
        _pool = await asyncpg.create_pool(
            DB_URL, min_size=1, max_size=4, command_timeout=10
        )
    return _pool


def _load_dri_config() -> dict[str, Any]:
    global _dri_config
    try:
        with open(DRI_CONFIG_PATH, "r", encoding="utf-8") as f:
            _dri_config = yaml.safe_load(f) or {}
    except FileNotFoundError:
        logger.warning(
            "[trafego] DRI config %s nao encontrado — usando fallback Vini",
            DRI_CONFIG_PATH,
        )
        _dri_config = {
            "categories": {
                "trafego_pago": {
                    "primary": {"name": "Vinicius", "phone": VINI_PHONE},
                }
            }
        }
    return _dri_config


def _resolve_dri(category: str) -> dict[str, str]:
    cfg = _load_dri_config()
    cat = (cfg.get("categories") or {}).get(category) or {}
    primary = cat.get("primary") or {"name": "Vinicius", "phone": VINI_PHONE}
    return primary


def _dri_phones() -> set[str]:
    cfg = _load_dri_config()
    phones: set[str] = set()
    for cat in (cfg.get("categories") or {}).values():
        for key in ("primary", "backup", "escalation"):
            phone = ((cat or {}).get(key) or {}).get("phone")
            if phone:
                phones.add(str(phone).replace("+", "").replace(" ", ""))
    phones.add(VINI_PHONE)
    return phones


def parse_ack_card_id(text: str) -> int | None:
    for pattern in ACK_PATTERNS:
        match = pattern.search(text or "")
        if match:
            return int(match.group(1))
    return None


# ---- handler principal ----
async def handle_trafego_card_event(request: web.Request) -> web.Response:
    # 1. auth
    auth = request.headers.get("Authorization", "")
    if not EXPECTED_TOKEN:
        logger.error(
            "[trafego] HERMES_TRAFEGO_TOKEN nao configurado — recusando todas as requests"
        )
        return web.json_response(
            {"error": "server_token_unconfigured"}, status=503
        )
    if not auth.startswith("Bearer ") or auth[7:] != EXPECTED_TOKEN:
        return web.json_response({"error": "unauthorized"}, status=401)

    # 2. parse
    try:
        body = await request.json()
    except Exception:
        return web.json_response({"error": "invalid_json"}, status=400)

    required = ("category", "msg_text")
    missing = [k for k in required if not body.get(k)]
    if missing:
        return web.json_response(
            {"error": "missing_fields", "fields": missing}, status=400
        )

    pool = await _get_pool()
    payload_json = json.dumps(body, ensure_ascii=False)

    # 3. dedup
    mentorada_id = body.get("mentorada_id")
    category = body["category"]
    async with pool.acquire() as con:
        existing = None
        if mentorada_id:
            existing = await con.fetchrow(
                """
                SELECT id FROM hermes_event_log
                WHERE mentorada_id = $1 AND category = $2
                  AND created_at > NOW() - make_interval(secs => $3)
                  AND status NOT IN ('dropped_dedup')
                ORDER BY id DESC LIMIT 1
                """,
                mentorada_id,
                category,
                int(DEDUP_SECONDS),
            )

        if existing:
            await con.execute(
                """
                INSERT INTO hermes_event_log (
                    event_type, card_id, mentorada_id, mentorada_name, category,
                    group_jid, group_name, sender_jid, msg_text, msg_timestamp,
                    status, webhook_payload
                ) VALUES (
                    'trafego_card', $1, $2, $3, $4,
                    $5, $6, $7, $8, $9,
                    'dropped_dedup', $10::jsonb
                )
                """,
                body.get("card_id"),
                mentorada_id,
                body.get("mentorada_name"),
                category,
                body.get("group_jid"),
                body.get("group_name"),
                body.get("sender_jid"),
                body.get("msg_text"),
                body.get("msg_timestamp"),
                payload_json,
            )
            logger.info(
                "[trafego] dedup drop mentorada_id=%s category=%s prev_id=%s",
                mentorada_id,
                category,
                existing["id"],
            )
            return web.json_response(
                {"status": "dropped_dedup", "previous_event_id": existing["id"]}
            )

        # 4. INSERT log
        row = await con.fetchrow(
            """
            INSERT INTO hermes_event_log (
                event_type, card_id, mentorada_id, mentorada_name, category,
                group_jid, group_name, sender_jid, msg_text, msg_timestamp,
                status, webhook_payload
            ) VALUES (
                'trafego_card', $1, $2, $3, $4,
                $5, $6, $7, $8, $9,
                'triggered', $10::jsonb
            )
            RETURNING id
            """,
            body.get("card_id"),
            mentorada_id,
            body.get("mentorada_name"),
            category,
            body.get("group_jid"),
            body.get("group_name"),
            body.get("sender_jid"),
            body.get("msg_text"),
            body.get("msg_timestamp"),
            payload_json,
        )
        event_id = row["id"]

    # 5. dispara Goal background (nao bloqueia)
    asyncio.create_task(_run_trafego_goal(event_id, body))

    return web.json_response(
        {"status": "received", "event_id": event_id}
    )


