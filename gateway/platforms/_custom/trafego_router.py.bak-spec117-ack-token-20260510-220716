def _prompt_for_category(category: str) -> str:
    return CATEGORY_PROMPTS.get(category) or CATEGORY_PROMPTS["outro"]


async def _run_trafego_goal(event_id: int, body: dict[str, Any]) -> None:
    """SPEC-117 task 03 — Goal real cruzando Meta Ads + leads + transcricoes.

    Usa /v1/chat/completions loopback do proprio Hermes (port 8642).
    Tools registradas no Hermes sao auto-disponiveis (86 MCP tools).
    Output substitui o template antigo. Em caso de erro, fallback template.
    """
    pool = await _get_pool()
    category = body.get("category", "trafego_pago")
    mentorada_name = body.get("mentorada_name") or "(nao identificada)"
    mentorada_id = body.get("mentorada_id")
    group_name = body.get("group_name") or "(grupo)"
    msg_text = (body.get("msg_text") or "").strip()
    card_id = body.get("card_id") or f"event-{event_id}"

    diagnosis = ""
    goal_status = "notified"
    tools_data: dict[str, Any] = {}

    try:
        # Mentorada nao mapeada → fallback Vini direto sem Goal
        if not mentorada_id:
            dri = {"name": "Vinicius", "phone": VINI_PHONE}
            diagnosis = (
                f"⚠️ Mentorada NAO identificada no grupo {group_name}.\n"
                f"Trecho cru:\n\"{msg_text[:280]}\"\n\n"
                f"Card #{card_id} aberto. Verifique mapping group_jid em mentoradas."
            )
        else:
            dri = _resolve_dri(category)
            from agent.extensions.trafego_prefetch import (
                format_context_for_prompt,
                pre_fetch_mentorada_context,
            )

            tools_data = await pre_fetch_mentorada_context(body)
            context_block = format_context_for_prompt(tools_data)

            # SPEC-117 task 03 — DeepSeek API direta (sem loopback Hermes pra evitar deadlock)
            # Formato rico baseado na mensagem da mentorada + dados reais ja materializados.
            user_prompt = _prompt_for_category(category).format(
                mentorada_name=mentorada_name,
                mentorada_id=mentorada_id,
                group_name=group_name,
                category=category,
                msg_text=msg_text[:500],
                card_id=card_id,
                dri_name_for_prompt=dri.get("name", "DRI").split()[0],
                context_block=context_block,
            )
            deepseek_key = os.getenv("DEEPSEEK_API_KEY", "").strip()
            # deepseek-chat (nao-reasoning) — output direto, ~3x mais rapido que v4-pro pra formatacao
            deepseek_model = os.getenv("HERMES_TRAFEGO_GOAL_MODEL", "deepseek-chat").strip()
            if not deepseek_key:
                raise RuntimeError("DEEPSEEK_API_KEY ausente")

            try:
                async with aiohttp.ClientSession() as sess:
                    async with sess.post(
                        "https://api.deepseek.com/v1/chat/completions",
                        headers={
                            "Authorization": f"Bearer {deepseek_key}",
                            "Content-Type": "application/json",
                        },
                        json={
                            "model": deepseek_model,
                            "messages": [
                                {
                                    "role": "system",
                                    "content": "Tu es Hermes, supervisor operacional em portugues BR. Diagnostico curto, direto, humano. Usa apenas dados reais recebidos no prompt.",
                                },
                                {
                                    "role": "user",
                                    "content": user_prompt,
                                },
                            ],
                            "max_tokens": 500,
                            "temperature": 0.3,
                        },
                        timeout=aiohttp.ClientTimeout(total=45),
                    ) as resp:
                        data = await resp.json()
                        content = (
                            data.get("choices", [{}])[0]
                            .get("message", {})
                            .get("content", "")
                        )
                        if content and len(content) > 50:
                            diagnosis = content.strip()
                        else:
                            raise ValueError(
                                f"DeepSeek output curto/vazio: {content[:100]}"
                            )
            except Exception as goal_exc:
                logger.warning(
                    "[trafego] event_id=%s Goal real falhou (%s) — fallback template",
                    event_id,
                    goal_exc,
                )
                goal_status = "goal_fallback"
                diagnosis = (
                    f"🔔 Card #{card_id} — categoria {category}\n"
                    f"Mentorada: {mentorada_name}\n"
                    f"Grupo: {group_name}\n\n"
                    f"Trecho:\n\"{msg_text[:280]}\"\n\n"
                    f"⚠️ Diagnostico cruzado falhou (Hermes Goal nao executou). "
                    f"Verifica manualmente."
                )

        # envia WhatsApp via bridge Hermes
        sent_ok = await _send_whatsapp(dri["phone"], diagnosis)
        if not sent_ok:
            goal_status = "send_failed"

        async with pool.acquire() as con:
            await con.execute(
                """
                UPDATE hermes_event_log
                SET status = $1,
                    dri_phone = $2,
                    dri_name = $3,
                    dri_notified_at = NOW(),
                    goal_diagnosis = $4,
                    tools_data = $5::jsonb,
                    updated_at = NOW()
                WHERE id = $6
                """,
                goal_status,
                dri["phone"],
                dri["name"],
                diagnosis,
                json.dumps(tools_data, ensure_ascii=False),
                event_id,
            )
        logger.info(
            "[trafego] event_id=%s status=%s DRI=%s phone=%s",
            event_id,
            goal_status,
            dri["name"],
            dri["phone"],
        )
    except Exception:
        logger.exception("[trafego] Goal task failed event_id=%s", event_id)
        try:
            async with pool.acquire() as con:
                await con.execute(
                    "UPDATE hermes_event_log SET status='goal_error', updated_at=NOW() WHERE id=$1",
                    event_id,
                )
        except Exception:
            pass


async def _send_whatsapp(phone: str, message: str) -> bool:
    chat_id = f"{phone}@s.whatsapp.net"
    try:
        async with aiohttp.ClientSession() as sess:
            async with sess.post(
                BRIDGE_SEND_URL,
                json={"chatId": chat_id, "message": message},
                timeout=aiohttp.ClientTimeout(total=10),
            ) as resp:
                ok = 200 <= resp.status < 300
                if not ok:
                    txt = await resp.text()
                    logger.warning(
                        "[trafego] /send falhou status=%s body=%s",
                        resp.status,
                        txt[:200],
                    )
                return ok
    except Exception as exc:
        logger.warning("[trafego] /send exception: %s", exc)
        return False


async def handle_trafego_ack(request: web.Request) -> web.Response:
    provided = (
        request.headers.get("X-Hermes-Token")
        or request.headers.get("X-Fofo-Token")
        or request.headers.get("Authorization", "").removeprefix("Bearer ").strip()
    )
    if ACK_TOKEN and provided != ACK_TOKEN:
        return web.json_response({"ok": False, "reason": "unauthorized"}, status=401)

    try:
        body = await request.json()
    except Exception:
        return web.json_response({"ok": False, "reason": "invalid_json"}, status=400)

    text = str(body.get("text") or body.get("body") or "")
    sender_phone = str(body.get("senderPhone") or body.get("sender_phone") or "")
    sender_phone = re.sub(r"\D+", "", sender_phone)
    card_id = body.get("card_id") or parse_ack_card_id(text)
    if not card_id:
        return web.json_response({"ok": False, "reason": "no_card_id"}, status=400)
    if sender_phone not in _dri_phones():
        return web.json_response({"ok": False, "reason": "sender_not_dri"}, status=403)

    result = await process_trafego_ack(sender_phone=sender_phone, card_id=str(card_id))
    status = 200 if result.get("ok") else 404
    return web.json_response(result, status=status)


async def process_trafego_ack(sender_phone: str, card_id: str) -> dict[str, Any]:
    pool = await _get_pool()
    async with pool.acquire() as con:
        row = await con.fetchrow(
            """
            UPDATE hermes_event_log
            SET ack_received_at = COALESCE(ack_received_at, NOW()),
                status = 'acked',
                updated_at = NOW()
            WHERE card_id = $1
              AND dri_phone = $2
              AND status IN ('notified', 'goal_fallback', 'escalated_l1', 'escalated_l2')
            RETURNING id, mentorada_name, dri_name, dri_notified_at
            """,
            str(card_id),
            sender_phone,
        )
        if not row:
            return {"ok": False, "reason": "card_not_found_or_sender_mismatch"}

    classifier_ok = await _post_classifier_ack(card_id=str(card_id), sender_phone=sender_phone)
    delta_seconds = None
    if row["dri_notified_at"]:
        delta_seconds = int(
            (datetime.now(UTC) - row["dri_notified_at"]).total_seconds()
        )
    minutes = max(0, int((delta_seconds or 0) / 60))
    await _send_whatsapp(
        sender_phone,
        f"Card #{card_id} ack recebido. Registrei no Hermes em {minutes}min.",
    )
    return {
        "ok": True,
        "event_id": row["id"],
        "card_id": str(card_id),
        "classifier_ack_ok": classifier_ok,
        "delta_seconds": delta_seconds,
    }


async def _post_classifier_ack(card_id: str, sender_phone: str) -> bool:
    token = os.environ.get("TRAFEGO_API_TOKEN") or os.environ.get("FOFO_INBOUND_TOKEN") or ""
    headers = {"Authorization": f"Bearer {token}"} if token else {}
    try:
        async with aiohttp.ClientSession() as sess:
            async with sess.post(
                f"{TRAFEGO_API_URL}/api/trafego/cards/{card_id}/ack",
                json={"owner": sender_phone, "source": "hermes_ack"},
                headers=headers,
                timeout=aiohttp.ClientTimeout(total=5),
            ) as resp:
                if 200 <= resp.status < 300:
                    return True
                logger.warning("[trafego] classifier ack status=%s", resp.status)
                return False
    except Exception as exc:
        logger.warning("[trafego] classifier ack exception: %s", exc)
        return False


# ---- mount ----
def mount_trafego_subapp(parent_app: web.Application, adapter: Any) -> None:
    """Monta route direto em /api/webhook/trafego-card-event.

    NAO usa add_subapp("/api/webhook", ...) porque alerts_router ja registra
    esse prefix e aiohttp nao aceita subapps duplicados no mesmo prefix.
    """
    parent_app.router.add_post(
        "/api/webhook/trafego-card-event", handle_trafego_card_event
    )
    parent_app.router.add_post(
        "/api/webhook/trafego-ack", handle_trafego_ack
    )
    parent_app.router.add_post(
        "/api/trafego/hermes-ack", handle_trafego_ack
    )
    logger.info(
        "[custom_extensions] trafego routes mounted"
    )
